<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/vaani_surface"
    android:padding="24dp">

    <!-- Large status / transcript text, Telugu-first -->
    <TextView
        android:id="@+id/statusText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/tap_to_speak"
        android:textColor="@color/vaani_on_surface"
        android:textSize="28sp"
        android:textStyle="bold"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/micButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Big, accessible mic button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/micButton"
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:text="🎤"
        android:textSize="64sp"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        app:cornerRadius="90dp"
        app:backgroundTint="@color/vaani_saffron"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/hintText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/prompt_example"
        android:textColor="@color/vaani_on_surface"
        android:textSize="18sp"
        android:gravity="center"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/micButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Debug-only: type a Telugu command to drive the pipeline without the mic. -->
    <EditText
        android:id="@+id/debugInput"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="@string/debug_hint"
        android:textColor="@color/vaani_on_surface"
        android:textSize="16sp"
        android:inputType="textNoSuggestions"
        android:imeOptions="actionSend"
        android:autofillHints="@null"
        android:layout_marginTop="48dp"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="8dp"
        app:layout_constraintTop_toBottomOf="@id/hintText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/debugSend" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/debugSend"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/debug_send"
        app:backgroundTint="@color/vaani_saffron"
        app:layout_constraintTop_toTopOf="@id/debugInput"
        app:layout_constraintBottom_toBottomOf="@id/debugInput"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
